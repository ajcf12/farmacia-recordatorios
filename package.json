{
  "name": "farmacia-recordatorios",
  "version": "1.1.6",
  "description": "Sistema de recordatorios para farmacia — Rx30 + Twilio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "pkg server.js --target node18-win-x64 --output farmacia.exe --compress GZip"
  },
  "pkg": {
    "assets": [
      "lib/**/*",
      "node_modules/csv-parse/dist/cjs/**/*"
    ],
    "scripts": [
      "server.js",
      "lib/*.js"
    ]
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "express": "^5.2.1",
    "mssql": "^10.0.4",
    "multer": "^2.1.1",
    "twilio": "^5.3.5"
  },
  "devDependencies": {
    "electron": "^29.1.0"
  }
}
